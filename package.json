    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
